{
  "name": "filemayor-launch-video",
  "version": "1.0.0",
  "private": true,
  "description": "FileMayor — 60s cinematic 3D product launch video (Remotion + React Three Fiber).",
  "scripts": {
    "studio": "remotion studio",
    "render": "remotion render Master60 ../out/filemayor-launch-60s.mp4 --codec h264 --crf 16 --image-format jpeg --jpeg-quality 95",
    "render:15s": "remotion render Cut15 ../out/filemayor-launch-15s.mp4 --codec h264 --crf 16",
    "render:6s": "remotion render Cut6 ../out/filemayor-launch-6s.mp4 --codec h264 --crf 16",
    "render:4k": "remotion render Master60 ../out/filemayor-launch-60s-4k.mp4 --codec h264 --crf 16 --scale 2 --timeout 240000 --concurrency 3",
    "render:15s:4k": "remotion render Cut15 ../out/filemayor-launch-15s-4k.mp4 --codec h264 --crf 16 --scale 2 --timeout 240000 --concurrency 3",
    "render:6s:4k": "remotion render Cut6 ../out/filemayor-launch-6s-4k.mp4 --codec h264 --crf 16 --scale 2 --timeout 240000 --concurrency 3"
  },
  "dependencies": {
    "@react-three/fiber": "^8.17.10",
    "@remotion/cli": "^4.0.246",
    "@remotion/fonts": "^4.0.246",
    "@remotion/three": "^4.0.246",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "remotion": "^4.0.246",
    "three": "^0.170.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/three": "^0.170.0",
    "typescript": "^5.6.3"
  }
}
